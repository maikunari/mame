# Mame — Environment Variables
# Copy this to .env and fill in your values:  cp deploy/.env.example .env

# --- Required ---

# Encryption key for the secrets vault (generate with: openssl rand -hex 32)
MAME_MASTER_KEY=

# Domain for HTTPS (used by Caddy for auto-SSL)
MAME_DOMAIN=mame.yourdomain.com

# --- Model API Keys (at least one required) ---

# Direct Anthropic API
ANTHROPIC_API_KEY=

# Google AI (for google/ prefixed models like gemini-3.1-flash-lite-preview)
GOOGLE_API_KEY=

# OpenRouter (for openrouter/ prefixed models)
OPENROUTER_API_KEY=

# --- Messaging ---

# Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# LINE (optional — for Japanese-language personas)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- Tools (optional) ---

# Web search (Brave Search — free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=

# Web search fallback (Serper — Google results)
SERPER_API_KEY=

# GitHub (for github tool — repo access, PRs, issues)
GITHUB_TOKEN=

# AgentMail (for email tool)
AGENTMAIL_API_KEY=

# --- Persona ---

# Which persona to run (matches filename in ~/.mame/personas/)
MAME_PERSONA=default
